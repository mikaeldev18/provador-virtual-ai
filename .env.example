# ──────────────────────────────────────────────────────────────
# ProvadorVirtualAI – Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: NEXT_PUBLIC_APP_URL=https://provadorvirtual.ai

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere-uma-string-secreta-aleatoria-aqui
# Gere com: openssl rand -base64 32

# Banco de Dados (SQLite para dev, PostgreSQL para prod)
DATABASE_URL="file:./dev.db"
# PostgreSQL: DATABASE_URL="postgresql://user:pass@host:5432/provadorvirtual"

# ──────────────────────────────────────────────────────────────
# Abacate Pay (https://abacatepay.com/docs)
# ──────────────────────────────────────────────────────────────
ABACATEPAY_API_KEY=seu_api_key_aqui
# Produção: sk_live_...
# Sandbox:  sk_test_...

ABACATEPAY_WEBHOOK_SECRET=seu_webhook_secret_aqui
# Configure no painel do Abacate Pay → Webhooks
# URL do webhook: https://seudominio.com/api/webhook/abacatepay

# ──────────────────────────────────────────────────────────────
# Replicate AI (https://replicate.com)
# Para o virtual try-on (modelo CatVTON)
# ──────────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_seu_token_aqui
# Gere em: https://replicate.com/account/api-tokens
